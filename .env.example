# ==========================================
# SuperClaw 环境变量示例
# 复制此文件为 .env 并填写实际值
# ==========================================

# ==========================================
# 基础配置
# ==========================================

# 应用名称
APP_NAME=SuperClaw
APP_VERSION=1.0.0
APP_ENV=development

# 服务器配置
BIND_ADDRESS=0.0.0.0
PORT=3000

# 调试模式
DEBUG=false

# ==========================================
# 数据库配置
# ==========================================

# SQLite（开发环境）
DATABASE_URL=sqlite:///app/data/superclaw.db

# PostgreSQL（生产环境）
# DATABASE_URL=postgresql://superclaw:password@postgres:5432/superclaw

# Redis 缓存
REDIS_URL=redis://localhost:6379/0

# ==========================================
# OpenClaw Gateway 配置
# ==========================================

OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_GATEWAY_TOKEN=your_openclaw_token_here

# ==========================================
# LemClaw Gateway 配置
# ==========================================

LEMLAW_GATEWAY_URL=http://localhost:8089
LEMLAW_AUTH_TOKEN=your_lemclaw_token_here

# ==========================================
# 日志配置
# ==========================================

# 日志级别：debug, info, warn, error
LOG_LEVEL=info

# 日志文件路径
LOG_FILE=logs/superclaw/app.log
AUDIT_LOG_FILE=logs/superclaw/audit.log

# ==========================================
# 安全配置
# ==========================================

# IP 白名单（逗号分隔）
IP_WHITELIST_ENABLED=false
IP_WHITELIST=127.0.0.1,192.168.1.0/24

# 速率限制
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

# 令牌白名单
TOKEN_WHITELIST_ENABLED=false
TOKEN_WHITELIST=token1,token2,token3

# ==========================================
# 浏览器配置
# ==========================================

BROWSER_ENABLED=true
BROWSER_TIMEOUT_MS=30000

# ==========================================
# 智能体编排配置
# ==========================================

# 最大并行智能体数
MAX_CONCURRENT_AGENTS=5

# 默认超时时间（毫秒）
DEFAULT_AGENT_TIMEOUT_MS=60000

# ==========================================
# Docker 配置
# ==========================================

# Docker 镜像仓库
DOCKER_REGISTRY=ghcr.io/aqzzzaq

# ==========================================
# CI/CD 配置
# ==========================================

# 部署主机
DEPLOY_HOST=your-deploy-host.com
DEPLOY_USER=deploy
DEPLOY_KEY=/path/to/ssh/key
