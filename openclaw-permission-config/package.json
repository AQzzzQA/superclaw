    "config",
    "qqbot",
    "visualization"
  ],
  "author": "Echo-2",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "multer": "^1.4.5-lts.1",
    "jsonschema": "^1.4.1",
    "winston": "^3.10.0",
    "uuid": "^9.0.0",
    "express-rate-limit": "^6.8.1",
    "compression": "^1.7.4",
    "fs-extra": "^11.1.1",
    "moment": "^2.29.4",
    "joi": "^17.9.2",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.1",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.5.0",
    "supertest": "^6.3.3",
    "eslint": "^8.44.0",
    "@types/node": "^20.4.2",
    "@types/express": "^4.17.17",
    "@types/cors": "^2.8.13",
    "@types/multer": "^1.4.7",
    "@types/jsonschema": "^1.4.0",
    "@types/uuid": "^9.0.2",
    "@types/compression": "^1.7.2",
    "@types/fs-extra": "^11.0.1",
    "@types/bcryptjs": "^2.4.2",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/js-yaml": "^4.0.5"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openclaw/openclaw-permission-config.git"
  },
  "bugs": {
    "url": "https://github.com/openclaw/openclaw-permission-config/issues"
