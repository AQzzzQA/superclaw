{
  "name": "openclaw-permission-config",
  "version": "1.0.0",
  "description": "OpenClaw权限配置可视化工具",
  "main": "index.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "cd frontend && npm run build",
    "install-deps": "pnpm install && cd frontend && pnpm install",
    "test": "jest",
    "lint": "eslint src/",
    "clean": "rm -rf node_modules frontend/node_modules pnpm-lock.yaml"
  },
  "keywords": [
