# 巨量引擎配置
OCEAN_APP_ID=your_app_id
OCEAN_APP_SECRET=your_app_secret
OCEAN_REDIRECT_URI=http://localhost:5173/oauth/callback
OCEAN_API_BASE_URL=https://api.oceanengine.com/open_api/v2.0

# 数据库配置
DATABASE_URL=mysql+pymysql://username:password@localhost:3306/dbname?charset=utf8mb4
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600

# Redis 配置
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=50

# 安全配置
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS 配置
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# App 配置
APP_NAME="Ad Platform API"
APP_VERSION="2.0.0"
DEBUG=false
ENVIRONMENT=production

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_ROTATION=1 day
LOG_RETENTION=30 days

# 限流配置
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_BURST=20

# Celery 配置
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_TIMEOUT=300

# 文件上传配置
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,mp4

# 监控配置
SENTRY_DSN=
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090

# 邮件配置（可选）
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# OAuth2 配置
OAUTH2_TOKEN_URL=https://api.oceanengine.com/open_api/oauth2/access_token/
OAUTH2_REFRESH_TOKEN_URL=https://api.oceanengine.com/open_api/oauth2/refresh_token/

# 记忆服务配置 (OpenViking Integration)
MEMORY_SERVER_URL=http://localhost:1933
MEMORY_API_KEY=
MEMORY_TIMEOUT=60
MEMORY_MAX_RETRIES=3
MEMORY_CACHE_SIZE=1000
MEMORY_DEFAULT_LAYER=L1
MEMORY_OPTIMIZATION_THRESHOLD=0.8

# 性能配置
WORKER_COUNT=4
WORKER_TIMEOUT=30
MAX_CONNECTIONS=100

# 监控配置
ENABLE_METRICS=true
METRICS_PORT=8090
