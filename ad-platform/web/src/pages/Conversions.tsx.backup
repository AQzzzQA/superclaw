import React from 'react'
import { Card, Typography, Button, Space, Table } from 'antd'
import { ReloadOutlined } from '@ant-design/icons'

const { Title, Text } = Typography

const ConversionsPage = () => {
  return (
    <div style={{ padding: 24, background: '#F5F7FA', minHeight: 'calc(100vh - 64px)' }}>
      <div style={{ marginBottom: 24, background: 'white', padding: 24 }}>
        <Title level={2}>转化追踪</Title>
        <Text type="secondary">页面描述</Text>
      </div>

      <div style={{ background: 'white', padding: 24 }}>
        <Space style={{ marginBottom: 16 }}>
          <Button icon={<ReloadOutlined />}>刷新</Button>
          <Button type="primary">添加</Button>
        </Space>

        <Table
          columns={[
            { title: 'ID', dataIndex: 'id', key: 'id' },
            { title: '名称', dataIndex: 'name', key: 'name' },
            { title: '描述', dataIndex: 'description', key: 'description' },
            { title: '状态', dataIndex: 'status', key: 'status' },
          ]}
          dataSource={[]}
          rowKey="id"
          pagination={{ pageSize: 10 }}
        />
      </div>
    </div>
  )
}

export default ConversionsPage
