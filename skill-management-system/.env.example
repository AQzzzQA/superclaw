# Skill Management System - Environment Configuration
# Copy this file to .env and update with your configuration

# Database Configuration
DATABASE_URL=sqlite:///./data/skills.db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=skill_management
DATABASE_USER=admin
DATABASE_PASSWORD=password123

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@skill-management.com

# Security Configuration
SECRET_KEY=your-secret-key-here-change-this-in-production
JWT_SECRET=your-jwt-secret-here-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION=24h

# System Configuration
MAX_WORKSPACES_PER_USER=10
MAX_SKILLS_PER_WORKSPACE=100
MAX_SKILLS_PER_USER=50
MAX_CONCURRENT_INSTALLATIONS=3
INSTALLATION_TIMEOUT=3600

# File Storage Configuration
SKILL_STORAGE_PATH=./data/skills
AUDIT_LOG_PATH=./data/audit
USER_DATA_PATH=./data/users
WORKSPACE_DATA_PATH=./data/workspaces

# Monitoring Configuration
ENABLE_MONITORING=true
MONITORING_INTERVAL=300
MONITORING_RETENTION_DAYS=90

# Feature Flags
ENABLE_EMAIL_NOTIFICATIONS=true
ENABLE_AUDIT_LOGGING=true
ENABLE_SKILL_APPROVALS=false
ENABLE_RATE_LIMITING=true

# Development Configuration
DEBUG=false
LOG_LEVEL=INFO
ENABLE_CORS=true
API_RATE_LIMIT=1000

# Integration Configuration
# GitHub integration (for skill registry)
GITHUB_TOKEN=your-github-token
GITHUB_OWNER=your-org
GITHUB_REPO=skill-registry

# Slack integration
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
SLACK_CHANNEL=#skill-notifications

# Docker Configuration
DOCKER_REGISTRY=registry.example.com
DOCKER_NAMESPACE=skill-management
DOCKER_TAG=latest

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_COMPRESSION=true

# API Configuration
API_VERSION=v1
API_PORT=8080
API_HOST=0.0.0.0
API_WORKERS=4

# Cache Configuration
CACHE_TYPE=redis
CACHE_URL=redis://localhost:6379
CACHE_TTL=3600

# Search Configuration
SEARCH_ENGINE=elasticsearch
SEARCH_URL=http://localhost:9200
SEARCH_INDEX=skills

# Logging Configuration
LOG_FORMAT=json
LOG_FILE=./logs/skill-management.log
LOG_ROTATION=true
LOG_MAX_SIZE=10MB
LOG_BACKUP_COUNT=5

# Performance Configuration
ENABLE_COMPRESSION=true
ENABLE_CACHING=true
ENABLE_ASYNC_TASKS=true
TASK_QUEUE_SIZE=1000

# Compliance Configuration
COMPLIANCE_LEVEL=standard
DATA_RETENTION_DAYS=365
AUDIT_TRAIL=true
ACCESS_LOGS=true

# Configuration for different environments
# Development
ENVIRONMENT=development
DEV_DATABASE_URL=sqlite:///./data/skills_dev.db
DEV_LOG_LEVEL=DEBUG

# Staging
ENVIRONMENT=staging
STAGING_DATABASE_URL=postgresql://user:pass@localhost:5432/skill_mgmt_staging
STAGING_LOG_LEVEL=INFO

# Production
ENVIRONMENT=production
PROD_DATABASE_URL=postgresql://user:pass@prod-db:5432/skill_mgmt_prod
PROD_LOG_LEVEL=WARNING
PROD_ENABLE_MONITORING=true
PROD_ENABLE_AUDIT_LOGGING=true