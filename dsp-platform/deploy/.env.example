# ==================== 环境配置 ====================
# 环境标识: development | staging | production
ENVIRONMENT=development

# ==================== 域名配置 ====================
DOMAIN_NAME=your-domain.com

# ==================== 数据库配置 ====================
MYSQL_ROOT_PASSWORD=your-strong-root-password
MYSQL_PASSWORD=your-strong-password

# ==================== Redis配置 ====================
REDIS_PASSWORD=your-redis-password

# ==================== 应用配置 ====================
JWT_SECRET=your-jwt-secret-key-min-32-chars
SENTRY_DSN=your-sentry-dsn-optional

# ==================== Grafana配置 ====================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your-strong-grafana-password

# ==================== ElasticSearch配置 ====================
ELASTIC_PASSWORD=your-elastic-password

# ==================== 邮件告警配置 ====================
ALERTMANAGER_SMTP_FROM=alerts@your-domain.com
ALERTMANAGER_SMTP_TO=your-email@example.com
ALERTMANAGER_SMTP_HOST=smtp.gmail.com
ALERTMANAGER_SMTP_PORT=587
ALERTMANAGER_SMTP_USER=your-smtp-username
ALERTMANAGER_SMTP_PASSWORD=your-smtp-password

# ==================== 钉钉告警配置 ====================
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=your-token
DINGTALK_SECRET=your-secret

# ==================== 企业微信告警配置 ====================
WECHAT_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-key
